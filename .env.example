# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
# Use a reusable key to survive container restarts
TS_AUTHKEY=

# Immich database credentials
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE_NAME=immich

# Timezone
TZ=Europe/Rome

# Immich storage paths (adjust for your NAS volume)
UPLOAD_LOCATION=/share/CACHEDEV3_DATA/immich/upload
DB_DATA_LOCATION=/share/CACHEDEV3_DATA/immich/db

# Backup configuration
X_BACKUP_VOLUME=/share/external/DEV3304_1
X_BACKUP_LOCATION=/immich
X_MEDIA_LIB=/share/CACHEDEV3_DATA/media
